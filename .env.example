FLEXPAY_CHECK_URL=https://apicheck.flexpaie.com/api/rest/v1/check
FLEXPAY_DEFAULT_CURRENCY=USD
FLEXPAY_MERCHANT=your_merchant_code
FLEXPAY_WEBHOOK_SECRET=your_webhook_secret

# App
